# Server Config
PORT=5000
NODE_ENV=development

# PostgreSQL Database Config
DB_HOST=localhost
DB_PORT=5432
DB_NAME=firegard_db
DB_USER=postgres
DB_PASSWORD=1234

# OR (Preferred - Single URL)
DATABASE_URL=postgresql://postgres:1234@localhost:5432/firegard_db

# JWT Auth
JWT_SECRET=your_super_secret_key
JWT_EXPIRE=7d

# CORS
CLIENT_URL=http://localhost:5173